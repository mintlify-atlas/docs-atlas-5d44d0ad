  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo-light.png",
    "dark": "/logo-dark.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/invopop/popui"
    }
  },
  "footer": {
